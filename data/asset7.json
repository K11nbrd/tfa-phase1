  "eligibility_rules": {
    "minimum_tenure_days": 365,
    "departure_reasons": [
      {
        "id": "isveren_feshi",
        "label_tr": "İşveren tarafından fesih (haklı neden dışında)",
        "eligible": true,
        "requires_minimum_tenure_days": 365,
        "notice_entitlement": true,
        "verdict_text_tr": "Kıdem tazminatına hak kazandınız. İşveren feshi durumunda en az 1 yıl kıdem şartıyla kıdem tazminatı ödenir; ayrıca ihbar tazminatı talep edebilirsiniz.",
        "statute_citation": "1475 sayılı İş Kanunu Madde 14; 4857 sayılı İş Kanunu Madde 17"
      },
      {
        "id": "istifa",
        "label_tr": "İşçinin istifası (haklı neden dışında)",
        "eligible": false,
        "requires_minimum_tenure_days": 0,
        "notice_entitlement": false,
        "verdict_text_tr": "Haklı bir neden olmaksızın istifa halinde kıdem tazminatına hak kazanılmaz. Belirli istisnai durumlar (askerlik, evlilik, emeklilik, sağlık, işverenin haklı neden teşkil eden davranışları) ayrı değerlendirilir.",
        "statute_citation": "1475 sayılı İş Kanunu Madde 14"
      },
      {
        "id": "evlilik",
        "label_tr": "Evlilik nedeniyle fesih (kadın işçi)",
        "eligible": true,
        "requires_minimum_tenure_days": 365,
        "notice_entitlement": false,
        "verdict_text_tr": "Kadın işçi, evlendiği tarihten itibaren bir yıl içinde iş sözleşmesini feshederse kıdem tazminatına hak kazanır. İhbar tazminatı bu durumda doğmaz.",
        "statute_citation": "1475 sayılı İş Kanunu Madde 14/1-(a)"
      },
      {
        "id": "emeklilik",
        "label_tr": "Emeklilik nedeniyle fesih",
        "eligible": true,
        "requires_minimum_tenure_days": 365,
        "notice_entitlement": false,
        "verdict_text_tr": "Yaşlılık aylığı, malullük aylığı veya toptan ödeme almak amacıyla iş sözleşmesini fesheden işçi kıdem tazminatına hak kazanır. SGK'dan alınacak yazı ile ispat edilir.",
        "statute_citation": "1475 sayılı İş Kanunu Madde 14/1"
      },
      {
        "id": "olum",
        "label_tr": "İşçinin ölümü",
        "eligible": true,
        "requires_minimum_tenure_days": 365,
        "notice_entitlement": false,
        "verdict_text_tr": "İşçinin ölümü halinde kıdem tazminatı kanuni mirasçılarına ödenir. Veraset ilamı ile başvuru yapılır.",
        "statute_citation": "1475 sayılı İş Kanunu Madde 14"
      },
      {
        "id": "askerlik",
        "label_tr": "Muvazzaf askerlik nedeniyle fesih",
        "eligible": true,
        "requires_minimum_tenure_days": 365,
        "notice_entitlement": false,
        "verdict_text_tr": "Muvazzaf askerlik hizmeti dolayısıyla iş sözleşmesini fesheden işçi kıdem tazminatına hak kazanır. Sevk belgesi ibrazı zorunludur.",
        "statute_citation": "1475 sayılı İş Kanunu Madde 14/1"
      },
      {
        "id": "saglik",
        "label_tr": "Sağlık nedenleriyle fesih",
        "eligible": true,
        "requires_minimum_tenure_days": 365,
        "notice_entitlement": false,
        "verdict_text_tr": "Sağlık sebepleri (4857/24-I) ile iş sözleşmesini haklı nedenle fesheden işçi kıdem tazminatına hak kazanır. Tam teşekküllü hastane raporu gereklidir.",
        "statute_citation": "4857 sayılı İş Kanunu Madde 24/I; 1475 sayılı İş Kanunu Madde 14"
      }
    ],
